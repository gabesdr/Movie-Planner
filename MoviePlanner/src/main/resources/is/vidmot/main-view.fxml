<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="is.vidmot.controller.MainController"
            styleClass="root-pane">

    <top>
        <VBox spacing="18" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="20" right="24" bottom="0" left="24"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar">
                <StackPane styleClass="brand-logo">
                    <Label styleClass="brand-logo-text" text="MP"/>
                </StackPane>

                <Label styleClass="app-title" text="Movie Planner"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT" spacing="8">
                    <Label fx:id="countLabel"
                           styleClass="count-label"
                           text="0 myndir á listanum"/>
                </HBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="search-row">
                <TextField fx:id="searchField"
                           styleClass="search-field"
                           promptText="Leita að kvikmynd..."
                           HBox.hgrow="ALWAYS"/>

                <Button fx:id="searchButton"
                        styleClass="search-button"
                        text="Leita"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="24" styleClass="tab-row">
                <Button fx:id="searchTabButton"
                        id="activeTab"
                        styleClass="tab-button"
                        text="Leit"/>

                <Button fx:id="watchlistTabButton"
                        styleClass="tab-button"
                        text="Minn listi (0)"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <VBox fx:id="searchView" spacing="22" visible="true" managed="true">
                <padding>
                    <Insets top="20" right="24" bottom="24" left="24"/>
                </padding>

                <Label fx:id="searchResultsTitle"
                       styleClass="section-title"
                       text="Vinsælar myndir"/>

                <Label fx:id="emptySearchLabel"
                       styleClass="empty-label"
                       text="Leitaðu að kvikmynd..."
                       visible="false"
                       managed="false"/>

                <ScrollPane fx:id="resultsScrollPane"
                            styleClass="results-scroll-pane"
                            fitToWidth="true"
                            fitToHeight="false"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED">
                    <content>
                        <FlowPane fx:id="resultsPane"
                                  styleClass="results-pane"
                                  hgap="18"
                                  vgap="18"
                                  prefWrapLength="1180"/>
                    </content>
                </ScrollPane>

                <HBox fx:id="loadMoreRow"
                      alignment="CENTER"
                      visible="false"
                      managed="false">
                    <Button fx:id="loadMoreButton"
                            styleClass="load-more-button"
                            text="Sjá fleiri"/>
                </HBox>
            </VBox>

            <VBox fx:id="watchlistView" spacing="22" visible="false" managed="false">
                <padding>
                    <Insets top="20" right="24" bottom="24" left="24"/>
                </padding>

                <Label styleClass="section-title" text="Minn listi"/>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="sort-label" text="Raða eftir"/>
                    <ComboBox fx:id="sortComboBox"
                              styleClass="sort-combo"
                              prefWidth="220"/>
                </HBox>

                <Label fx:id="emptyWatchlistLabel"
                       styleClass="empty-label"
                       text="Listinn þinn er tómur. Leitaðu að kvikmyndum og bættu þeim við!"/>

                <VBox fx:id="watchlistPane" fillWidth="true" spacing="16"/>
            </VBox>

            <StackPane fx:id="overlayPane"
                       styleClass="overlay-root"
                       visible="false"
                       managed="false">

                <StackPane fx:id="detailModal"
                           styleClass="detail-modal"
                           maxWidth="980">

                    <VBox spacing="0" fillWidth="true" prefWidth="980">
                        <HBox alignment="CENTER_RIGHT" styleClass="modal-header">
                            <Button fx:id="closeDetailButton"
                                    styleClass="close-button"
                                    text="✕"/>
                        </HBox>

                        <StackPane prefHeight="240" styleClass="detail-backdrop">
                            <ImageView fx:id="detailBackdropView"
                                       styleClass="detail-backdrop-image"
                                       fitWidth="980"
                                       fitHeight="240"
                                       preserveRatio="false"
                                       pickOnBounds="true"/>
                            <StackPane styleClass="detail-backdrop-overlay"/>
                        </StackPane>

                        <ScrollPane fx:id="detailScrollPane"
                                    styleClass="detail-scroll"
                                    fitToWidth="true"
                                    hbarPolicy="NEVER"
                                    vbarPolicy="AS_NEEDED">
                            <content>
                                <VBox spacing="0">
                                    <HBox alignment="TOP_LEFT" spacing="26" styleClass="detail-body">
                                        <ImageView fx:id="detailPosterView"
                                                   styleClass="detail-poster"
                                                   fitWidth="180"
                                                   fitHeight="270"
                                                   preserveRatio="false"/>

                                        <VBox spacing="16" HBox.hgrow="ALWAYS">
                                            <Label fx:id="detailTitleLabel"
                                                   styleClass="detail-title"/>

                                            <HBox alignment="CENTER_LEFT" spacing="16">
                                                <Label fx:id="detailRatingLabel"
                                                       styleClass="detail-meta-rating"/>

                                                <Label fx:id="detailDateLabel"
                                                       styleClass="detail-meta"/>

                                                <Label fx:id="detailRuntimeLabel"
                                                       styleClass="detail-meta"/>
                                            </HBox>

                                            <FlowPane fx:id="detailGenresPane"
                                                      hgap="8"
                                                      vgap="8"/>

                                            <Button fx:id="addToListButton"
                                                    styleClass="add-button"
                                                    text="+ Bæta á lista"/>

                                            <VBox spacing="10">
                                                <Label styleClass="subheading" text="Lýsing"/>
                                                <Label fx:id="detailDescriptionLabel"
                                                       styleClass="detail-description"
                                                       wrapText="true"/>
                                                <Hyperlink fx:id="toggleDescriptionLink"
                                                           styleClass="description-link"
                                                           text=""
                                                           visible="false"
                                                           managed="false"/>
                                            </VBox>

                                            <VBox spacing="12">
                                                <Label styleClass="subheading" text="Aðalleikarar"/>
                                                <FlowPane fx:id="detailActorsPane"
                                                          hgap="8"
                                                          vgap="8"/>
                                            </VBox>
                                        </VBox>
                                    </HBox>

                                    <VBox spacing="12" styleClass="trailer-section">
                                        <StackPane alignment="CENTER" styleClass="trailer-center-wrap">
                                            <StackPane fx:id="trailerContainer"
                                                       styleClass="trailer-container"
                                                       prefHeight="220"
                                                       minHeight="220"
                                                       maxWidth="720">
                                                <VBox fx:id="trailerFallbackBox"
                                                      alignment="CENTER"
                                                      spacing="14"
                                                      styleClass="trailer-fallback-box">
                                                    <Label fx:id="noTrailerLabel"
                                                           styleClass="trailer-empty"
                                                           text="Sýnishorn ekki til"/>

                                                    <Button fx:id="openTrailerButton"
                                                            styleClass="trailer-button"
                                                            text="Horfa á YouTube"
                                                            visible="false"
                                                            managed="false"/>
                                                </VBox>
                                            </StackPane>
                                        </StackPane>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </VBox>
                </StackPane>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>