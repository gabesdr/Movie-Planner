<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="is.vidmot.controller.MainController"
            styleClass="root-pane">

    <top>
        <VBox spacing="18" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="20" right="24" bottom="0" left="24"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="top-bar">
                <StackPane styleClass="brand-logo">
                    <Label text="MP" styleClass="brand-logo-text"/>
                </StackPane>

                <Label text="Movie Planner" styleClass="app-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <Label fx:id="countLabel" styleClass="count-label" text="0 myndir á listanum"/>
                </HBox>
            </HBox>

            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="search-row">
                <TextField fx:id="searchField"
                           promptText="Leita að kvikmynd..."
                           HBox.hgrow="ALWAYS"
                           styleClass="search-field"/>

                <Button fx:id="searchButton"
                        text="Leita"
                        styleClass="search-button"/>
            </HBox>

            <HBox spacing="24" alignment="CENTER_LEFT" styleClass="tab-row">
                <Button fx:id="searchTabButton"
                        id="activeTab"
                        text="Leit"
                        styleClass="tab-button"/>

                <Button fx:id="watchlistTabButton"
                        text="Minn listi (0)"
                        styleClass="tab-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <VBox fx:id="searchView" spacing="22" visible="true" managed="true">
                <padding>
                    <Insets top="20" right="24" bottom="24" left="24"/>
                </padding>

                <Label fx:id="searchResultsTitle"
                       styleClass="section-title"
                       text="Leitarniðurstöður (0)"/>

                <Label fx:id="emptySearchLabel"
                       styleClass="empty-label"
                       text="Leitaðu að kvikmynd..."/>

                <ScrollPane fx:id="resultsScrollPane"
                            fitToWidth="true"
                            fitToHeight="false"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            styleClass="results-scroll-pane">
                    <content>
                        <FlowPane fx:id="resultsPane"
                                  hgap="18"
                                  vgap="18"
                                  prefWrapLength="1180"
                                  styleClass="results-pane"/>
                    </content>
                </ScrollPane>
            </VBox>

            <VBox fx:id="watchlistView" spacing="22" visible="false" managed="false">
                <padding>
                    <Insets top="20" right="24" bottom="24" left="24"/>
                </padding>

                <Label styleClass="section-title" text="Minn listi"/>

                <Label fx:id="emptyWatchlistLabel"
                       styleClass="empty-label"
                       text="Listinn þinn er tómur. Leitaðu að kvikmyndum og bættu þeim við!"/>

                <VBox fx:id="watchlistPane" fillWidth="true" spacing="16"/>
            </VBox>

            <StackPane fx:id="overlayPane"
                       visible="false"
                       managed="false"
                       styleClass="overlay-root">

                <StackPane maxWidth="980"
                           maxHeight="640"
                           styleClass="detail-modal">

                    <VBox spacing="0" fillWidth="true" prefWidth="980" prefHeight="640">

                        <HBox alignment="CENTER_RIGHT" styleClass="modal-header">
                            <Button fx:id="closeDetailButton"
                                    text="×"
                                    styleClass="close-button"/>
                        </HBox>

                        <StackPane prefHeight="240" styleClass="detail-backdrop"/>

                        <HBox spacing="26" alignment="TOP_LEFT" styleClass="detail-body">
                            <ImageView fx:id="detailPosterView"
                                       fitWidth="180"
                                       fitHeight="270"
                                       preserveRatio="false"
                                       styleClass="detail-poster"/>

                            <VBox spacing="16" HBox.hgrow="ALWAYS">
                                <Label fx:id="detailTitleLabel"
                                       styleClass="detail-title"/>

                                <HBox spacing="16" alignment="CENTER_LEFT">
                                    <Label fx:id="detailRatingLabel"
                                           styleClass="detail-meta-rating"/>

                                    <Label fx:id="detailDateLabel"
                                           styleClass="detail-meta"/>

                                    <Label fx:id="detailRuntimeLabel"
                                           styleClass="detail-meta"/>
                                </HBox>

                                <FlowPane fx:id="detailGenresPane" hgap="8" vgap="8"/>

                                <Button fx:id="addToListButton"
                                        text="+ Bæta á lista"
                                        styleClass="primary-button add-button"/>

                                <VBox spacing="10">
                                    <Label text="Lýsing" styleClass="subheading"/>
                                    <Label fx:id="detailDescriptionLabel"
                                           wrapText="true"
                                           styleClass="detail-description"/>
                                </VBox>

                                <VBox spacing="12">
                                    <Label text="Aðalleikarar" styleClass="subheading"/>
                                    <FlowPane fx:id="detailActorsPane" hgap="8" vgap="8"/>
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </StackPane>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>